generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js (NextAuth) ──────────────────────────────
// These four tables (User, Account, Session, VerificationToken)
// match the shape Auth.js expects when using the Prisma adapter.
// https://authjs.dev/reference/adapter/prisma

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  // TMOS-specific: hourly rate for the "X hours of your life" feature (Phase 5)
  hourlyRateCents Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  categories    Category[]
  subscriptions Subscription[]
  budgets       Budget[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Money ───────────────────────────────────────────
// Categories are user-owned (everyone has their own "Groceries").
// `kind` distinguishes income categories (Salary) from expense categories (Food).
enum CategoryKind {
  INCOME
  EXPENSE
}

model Category {
  id     String       @id @default(cuid())
  userId String
  name   String
  color  String // hex like "#22c55e"
  kind   CategoryKind
  icon   String? // optional emoji or icon name

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
}

// Transactions track money in/out. Amount is stored in cents (Int)
// to avoid floating-point rounding errors — $12.34 is stored as 1234.
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL // user typed it in
  CSV // imported from a bank CSV
  API // pulled from Plaid etc. (Phase 7+)
}

// How the transaction's category was chosen.
// MANUAL  — user picked it themselves
// RULES   — keyword rules engine matched (Phase 1)
// AI      — LLM fallback chose it (Phase 2)
enum CategorizationSource {
  MANUAL
  RULES
  AI
}

model Transaction {
  id             String            @id @default(cuid())
  userId         String
  amountCents    Int
  type           TransactionType
  categoryId     String?
  occurredAt     DateTime // when the money actually moved
  source         TransactionSource
  rawDescription String // original text from bank / user input
  merchant       String? // cleaned merchant name (e.g. "Starbucks")
  note           String? // user's own note

  // How the categoryId was chosen, and how confident we were (AI only).
  categorizationSource CategorizationSource @default(MANUAL)
  confidence           Float? // 0..1, set by AI categorizer; null otherwise

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
}

// Detected recurring charges. Populated by the subscription detector (Phase 2).
enum SubscriptionCadence {
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAUSED
}

model Subscription {
  id             String              @id @default(cuid())
  userId         String
  name           String // "Netflix", "Spotify"
  amountCents    Int
  cadence        SubscriptionCadence
  nextExpectedAt DateTime?
  status         SubscriptionStatus  @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// Monthly spending caps per category. `month` is stored as the first day of the month.
model Budget {
  id                String   @id @default(cuid())
  userId            String
  categoryId        String
  monthlyLimitCents Int
  month             DateTime // YYYY-MM-01 00:00:00

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}
