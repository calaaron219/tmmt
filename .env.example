# ─── Database (Railway Postgres or Neon) ─────────────────
# Copy from Railway → Postgres service → Variables tab
DATABASE_URL="postgresql://user:password@host:5432/tmmt?schema=public"

# ─── Redis (Railway Redis) — used from Phase 4 onward ────
REDIS_URL="redis://default:password@host:6379"

# ─── Auth.js (Phase 1) ───────────────────────────────────
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# AUTH_URL: base URL of your deployed web app (production only)
# Locally Next.js auto-detects; in Vercel set to your Vercel URL.
# AUTH_URL="https://your-app.vercel.app"

# GitHub OAuth — https://github.com/settings/developers
# Authorization callback URL: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Anthropic Claude (Phase 2+) ─────────────────────────
ANTHROPIC_API_KEY=""

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NODE_ENV="development"
